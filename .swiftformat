# Configured for SwiftFormat 0.61.1 — pin in .pre-commit-config.yaml and .github/workflows/lint.yml
# Day-1 ruleset: defaults tuned for CloudNow's existing style (zero tabs, 4-space indent).
# Run "swiftformat --config .swiftformat CloudNow" to apply; "--lint" to verify.

# Targets Swift 5.10 (tvOS 17 / Xcode 16 baseline; bump when project moves to Swift 6).
--swiftversion 5.10

# CloudNow uses 4-space indentation throughout (zero tabs detected).
--indent 4

# Line-length policing is SwiftLint's job (and currently disabled there too — see .swiftlint.yml).
# File consistency > arbitrary cutoffs while max-line is 233 chars.
--maxwidth none

# Do NOT touch file headers — CloudNow has none today; don't inject copyright noise.
--header ignore

# Skip build artifacts and SPM checkout dirs (mirrors .swiftlint.yml's excluded list).
--exclude .build,.swiftpm,DerivedData,Packages,.spm-packages
